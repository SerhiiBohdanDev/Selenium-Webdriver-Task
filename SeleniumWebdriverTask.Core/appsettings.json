{
  "Configuration": {
    "BrowserType": "Firefox",
    "ApplicationUrl": "https://www.epam.com",
    "Headless": false
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": "Information",
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "restrictedToMinimumLevel": "Information"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "log.txt",
          "restrictedToMinimumLevel": "Warning"
        }
      }
    ]
  }
}
